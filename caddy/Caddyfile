# Main website
mediatoken.de {
	reverse_proxy web:3000
}

# API
api.mediatoken.de {
	reverse_proxy api:4000
}

# Download client reverse proxy — wildcard with DNS-01 challenge
*.dl.mediatoken.de {
	tls {
		dns hetzner {env.HETZNER_API_TOKEN}
		propagation_delay 30s
		propagation_timeout 120s
	}

	basic_auth {
		{env.DL_AUTH_USER} {env.DL_AUTH_HASH}
	}

	# Map subdomain label to backend IP:port from the mapping file.
	# {labels.3} extracts the leftmost label: dl-a1b2c3d4.dl.mediatoken.de → "dl-a1b2c3d4"
	# (Caddy labels are 0-indexed from the right: 0=de, 1=mediatoken, 2=dl, 3=dl-a1b2c3d4)
	map {labels.3} {dl_backend} {
		import /etc/caddy/dl-backends.map
		default "none"
	}

	@has_backend expression `{dl_backend} != "none"`
	handle @has_backend {
		reverse_proxy {dl_backend}
	}

	handle {
		respond "Download client not found" 404
	}
}
