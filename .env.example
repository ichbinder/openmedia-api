# PostgreSQL (Docker)
POSTGRES_USER=cinescope
POSTGRES_PASSWORD=cinescope_dev
POSTGRES_DB=cinescope

# Express Server
DATABASE_URL=postgresql://cinescope:cinescope_dev@localhost:5432/cinescope
JWT_SECRET=change-me-in-production-use-a-long-random-string
PORT=4000

# TMDB API (optional — for NZB import auto-lookup)
TMDB_API_KEY=

# SABnzbd Downloader
SABNZBD_URL=http://192.168.1.100:8080
SABNZBD_API_KEY=your-sabnzbd-api-key
SABNZBD_CATEGORY=movies

# OpenMedia NZB Storage API
NZB_API_URL=http://localhost:4100

# Hetzner Object Storage (S3-compatible)
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://hel1.your-objectstorage.com
S3_BUCKET=openmedia-files
S3_REGION=hel1

# Hetzner Cloud API (for VM management)
HETZNER_API_TOKEN=your-hetzner-cloud-api-token

# NZB Service (serves NZB files by hash)
NZB_SERVICE_URL=https://nzb.nettoken.de

# Download Provisioning: "hetzner" (production) | "local" (dev) | "false" (disabled)
AUTO_PROVISION=hetzner
