datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  watchlist      WatchlistItem[]
  library        UserLibrary[]
  searchHistory  SearchHistory[]
  apiTokens      ApiToken[]

  @@map("users")
}

model ApiToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique @map("token_hash")   // SHA-256 hash — plaintext never stored
  tokenPrefix String    @map("token_prefix")          // "om_aBcDeFgH" — first 11 chars for display
  name        String                                   // user-given label: "Meine Extension"
  expiresAt   DateTime  @map("expires_at")
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")            // null = active, set = revoked
  createdAt   DateTime  @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@index([userId])
  @@map("api_tokens")
}

model WatchlistItem {
  id          String   @id @default(uuid())
  movieId     Int      @map("movie_id")
  title       String
  posterPath  String?  @map("poster_path")
  voteAverage Float    @default(0) @map("vote_average")
  releaseDate String   @default("") @map("release_date")
  addedAt     DateTime @default(now()) @map("added_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@unique([userId, movieId])
  @@map("watchlist_items")
}

model NzbMovie {
  id          String   @id @default(uuid())
  tmdbId      Int?     @unique @map("tmdb_id")
  imdbId      String?  @unique @map("imdb_id")
  titleDe     String   @map("title_de")
  titleEn     String   @map("title_en")
  description String   @default("")
  year        Int?
  posterPath  String?  @map("poster_path")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  nzbFiles NzbFile[]

  @@map("nzb_movies")
}

model NzbFile {
  id                String   @id @default(uuid())
  hash              String   @unique
  originalFilename  String   @map("original_filename")
  fileSize          BigInt?  @map("file_size")
  resolution        String?
  qualityTier       String?  @map("quality_tier")    // normalized: "480p", "720p", "1080p", "2160p"
  audioLanguages    String[] @default([]) @map("audio_languages")
  subtitleLanguages String[] @default([]) @map("subtitle_languages")
  codec             String?
  source            String   @default("external")  // 'external' | 'own'
  releaseType       String?  @map("release_type")  // 'BluRay' | 'WEB-DL' | 'WEBRip' etc.
  status            String   @default("untested")  // 'untested' | 'ok' | 'broken' | 'expired'
  brokenReason      String?  @map("broken_reason")
  failedAttempts    Int      @default(0) @map("failed_attempts")

  // Media metadata from ffprobe (populated for both source='own' and source='external' NzbFiles)
  videoWidth        Int?     @map("video_width")
  videoHeight       Int?     @map("video_height")
  videoBitrate      Int?     @map("video_bitrate")       // kbps
  videoFramerate    String?  @map("video_framerate")      // "23.976", "25", "29.97"
  videoColorDepth   Int?     @map("video_color_depth")    // 8, 10, 12
  hdr               Boolean? @map("hdr")
  hdrFormat         String?  @map("hdr_format")           // "HDR10", "HDR10+", "Dolby Vision", "HLG"
  audioCodec        String?  @map("audio_codec")          // primary track: "AAC", "DTS", "AC3"
  audioChannels     String?  @map("audio_channels")       // primary track: "2.0", "5.1", "7.1"
  audioBitrate      Int?     @map("audio_bitrate")        // primary track kbps
  duration          Int?     @map("duration")             // seconds
  mediaInfo         Json?    @map("media_info")           // full ffprobe JSON output

  // S3 storage reference (set after successful download + upload)
  s3Key             String?  @map("s3_key")
  s3StreamKey       String?  @map("s3_stream_key")  // browser-streamable MP4 version
  s3Bucket          String?  @map("s3_bucket")
  fileExtension     String?  @map("file_extension")
  downloadedAt      DateTime? @map("downloaded_at")

  // Lifecycle management
  lastAccessedAt       DateTime? @map("last_accessed_at")       // updated on every presigned URL request
  scheduledDeletionAt  DateTime? @map("scheduled_deletion_at")  // set when LRU cleanup marks for deletion

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Nullable: when a NZB upload cannot be matched to a TMDB movie (not_found or transient error),
  // the NzbFile is created without a movie. The DownloadJob enters status='needs_review' and waits
  // for the user to assign a movie manually, or for the background TMDB retry to succeed.
  movie   NzbMovie? @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId String?   @map("movie_id")

  downloadJobs DownloadJob[]
  uploadJobs   UploadJob[]
  libraryUsers UserLibrary[]

  @@index([movieId])
  @@index([source])
  @@map("nzb_files")
}

model UserLibrary {
  id        String    @id @default(uuid())
  addedAt   DateTime  @default(now()) @map("added_at")
  removedAt DateTime? @map("removed_at")              // null = active, set = user removed from library

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String  @map("user_id")

  nzbFile   NzbFile @relation(fields: [nzbFileId], references: [id], onDelete: Cascade)
  nzbFileId String  @map("nzb_file_id")

  @@unique([userId, nzbFileId])
  @@index([nzbFileId])
  @@map("user_library")
}

model DownloadJob {
  id              String   @id @default(uuid())

  // Status: needs_review → queued → provisioning → downloading → uploading → completed | failed
  // needs_review: NzbFile has no movieId (TMDB lookup failed). Waiting for manual assignment
  //               or background TMDB retry. Provisioning is skipped for this status.
  status          String   @default("queued")
  progress        Int      @default(0)      // 0-100 percentage
  error           String?                    // error message if failed

  // Who started this download
  userId          String?  @map("user_id")

  // Hetzner VPS tracking
  hetznerServerId Int?     @map("hetzner_server_id")
  hetznerServerIp String?  @map("hetzner_server_ip")

  // Review flow (only relevant when status='needs_review')
  reviewExpiresAt DateTime? @map("review_expires_at") // job is failed + cleaned up after this moment
  tmdbRetryCount  Int      @default(0) @map("tmdb_retry_count")
  tmdbRetryAfter  DateTime? @map("tmdb_retry_after")  // reconciler attempts TMDB lookup again after this moment

  // Timing
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  nzbFile   NzbFile @relation(fields: [nzbFileId], references: [id], onDelete: Cascade)
  nzbFileId String  @map("nzb_file_id")
  vpsEvents VpsEvent[]

  @@index([nzbFileId])
  @@index([status])
  // Composite indexes for the S02 reconciler queries: expired needs_review
  // cleanup and background TMDB retry. Both filter by status first and then
  // by a timestamp column, so a composite index is the natural fit.
  @@index([status, reviewExpiresAt])
  @@index([status, tmdbRetryAfter])
  @@map("download_jobs")
}

model UploadJob {
  id              String   @id @default(uuid())

  // Status: queued → running → completed | failed
  status          String   @default("queued")
  error           String?                    // error message if failed

  // Hetzner VPS tracking (upload VPS is ephemeral)
  hetznerServerId Int?     @map("hetzner_server_id")
  hetznerServerIp String?  @map("hetzner_server_ip")

  // NZB result — set after Nyuu upload completes
  nzbHash         String?  @map("nzb_hash")   // sha256 of the created NZB file
  movieId         String?  @map("movie_id")   // target movie for the new NzbFile entry

  // Timing
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  nzbFile   NzbFile @relation(fields: [nzbFileId], references: [id], onDelete: Cascade)
  nzbFileId String  @map("nzb_file_id")
  vpsEvents VpsEvent[]

  @@index([nzbFileId])
  @@index([status])
  @@map("upload_jobs")
}

model ServiceToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")  // SHA-256 hash — plaintext never stored
  jobId     String   @map("job_id")
  jobType   String   @map("job_type")             // 'download' | 'upload'
  expiresAt DateTime @map("expires_at")           // Token auto-expires after TTL
  createdAt DateTime @default(now()) @map("created_at")

  @@index([jobId])
  @@map("service_tokens")
}

model SearchHistory {
  id          String   @id @default(uuid())
  movieId     Int      @map("movie_id")
  title       String
  posterPath  String?  @map("poster_path")
  voteAverage Float    @default(0) @map("vote_average")
  releaseDate String   @default("") @map("release_date")
  searchedAt  DateTime @default(now()) @map("searched_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  @@unique([userId, movieId])
  @@index([userId, searchedAt])
  @@map("search_history")
}

model EncryptedConfig {
  id              String   @id @default(uuid())
  key             String   @unique
  encryptedValue  String   @map("encrypted_value")
  iv              String                              // hex-encoded initialization vector
  tag             String                              // hex-encoded auth tag
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("encrypted_configs")
}

// ─── Centralized Config Store ──────────────────────────────────────────

model ConfigCategory {
  id          String   @id @default(uuid())
  name        String   @unique                        // "s3", "usenet_download", "usenet_upload"
  displayName String   @map("display_name")           // "S3 Storage", "Usenet Download"
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  entries  ConfigEntry[]
  profiles ConfigProfileCategory[]

  @@map("config_categories")
}

model ConfigEntry {
  id          String   @id @default(uuid())
  key         String                                   // "access_key", "servers" (unique within category)
  value       String   @db.Text                        // plaintext or AES-256-GCM encrypted (JSON for complex values)
  encrypted   Boolean  @default(false)                 // true → value is AES-256-GCM encrypted
  iv          String?                                  // hex-encoded IV (only when encrypted)
  tag         String?                                  // hex-encoded auth tag (only when encrypted)
  displayName String   @default("") @map("display_name") // "Access Key", "Usenet Servers"
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category   ConfigCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String         @map("category_id")

  history ConfigHistory[]

  @@unique([categoryId, key])
  @@index([categoryId])
  @@map("config_entries")
}

model ConfigProfile {
  id          String   @id @default(uuid())
  name        String   @unique                         // "download_vps", "upload_vps"
  displayName String   @map("display_name")            // "Download VPS", "Upload VPS"
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  categories ConfigProfileCategory[]

  @@map("config_profiles")
}

model ConfigProfileCategory {
  id         String @id @default(uuid())

  profile    ConfigProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId  String         @map("profile_id")

  category   ConfigCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String         @map("category_id")

  @@unique([profileId, categoryId])
  @@map("config_profile_categories")
}

model ConfigHistory {
  id         String   @id @default(uuid())
  action     String                                     // "created", "updated", "deleted"
  oldValue   String?  @map("old_value") @db.Text        // previous value ("[encrypted]" if secret)
  newValue   String?  @map("new_value") @db.Text        // new value ("[encrypted]" if secret)
  changedBy  String?  @map("changed_by")                // userId or "system"
  entryKey   String?  @map("entry_key")                 // preserved key for audit after entry deletion
  categoryName String? @map("category_name")            // preserved category for audit after entry deletion
  createdAt  DateTime @default(now()) @map("created_at")

  entry   ConfigEntry? @relation(fields: [entryId], references: [id], onDelete: SetNull)
  entryId String?      @map("entry_id")

  @@index([entryId])
  @@index([createdAt])
  @@index([categoryName, entryKey, createdAt])
  @@map("config_history")
}

// ─── VPS Runtime Events ──────────────────────────────────────────────

model VpsEvent {
  id              String   @id @default(uuid())
  downloadJobId   String?  @map("download_job_id")
  uploadJobId     String?  @map("upload_job_id")
  jobType         String   @map("job_type")             // 'download' | 'upload'
  eventType       String   @map("event_type")            // 'routing_anomaly' | 'vpn_down' | 'vpn_reconnect' | 'watchdog' | 'bootstrap'
  severity        String   @default("warning")           // 'info' | 'warning' | 'critical'
  details         Json                                    // structured event payload (interface, expected, actual, etc.)
  createdAt       DateTime @default(now()) @map("created_at")

  // FK relations — cascade delete when the parent job is removed
  downloadJob     DownloadJob? @relation(fields: [downloadJobId], references: [id], onDelete: Cascade)
  uploadJob       UploadJob?   @relation(fields: [uploadJobId], references: [id], onDelete: Cascade)

  @@index([downloadJobId, createdAt])
  @@index([uploadJobId, createdAt])
  @@index([downloadJobId, eventType, createdAt])
  @@index([uploadJobId, eventType, createdAt])
  @@map("vps_events")
}

// ─── Usenet Provider Store ──────────────────────────────────────────

model UsenetProvider {
  id          String   @id @default(uuid())
  name        String   @unique                        // display name: "Eweka", "EasyUsenet"
  host        String                                   // download hostname: "news.eweka.nl"
  postHost    String?  @map("post_host")               // upload hostname: "post.eweka.nl" (null = same as host)
  port        Int      @default(563)
  ssl         Boolean  @default(true)
  username    String                                   // plaintext or encrypted
  password    String   @db.Text                        // AES-256-GCM encrypted
  iv          String?                                  // hex-encoded IV (for password)
  tag         String?                                  // hex-encoded auth tag (for password)
  connections Int      @default(20)
  priority    Int      @default(0)                     // lower = higher priority
  enabled     Boolean  @default(true)
  isDownload  Boolean  @default(false) @map("is_download") // use for download VPS
  isUpload    Boolean  @default(false) @map("is_upload")   // use for upload VPS
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("usenet_providers")
}

// ─── VPN Provider Store ──────────────────────────────────────────

model VpnProvider {
  id              String   @id @default(uuid())
  name            String   @unique                        // display name: "Mullvad", "ProtonVPN"
  protocol        String                                   // 'wireguard' | 'openvpn'
  configBlob      String   @db.Text @map("config_blob")   // AES-256-GCM encrypted config file content
  configBlobIv    String   @map("config_blob_iv")          // hex-encoded IV
  configBlobTag   String   @map("config_blob_tag")         // hex-encoded auth tag
  username        String?                                  // AES-256-GCM encrypted (optional, mainly OpenVPN)
  usernameIv      String?  @map("username_iv")
  usernameTag     String?  @map("username_tag")
  password        String?  @db.Text                        // AES-256-GCM encrypted (optional)
  passwordIv      String?  @map("password_iv")
  passwordTag     String?  @map("password_tag")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("vpn_providers")
}

// ─── Service Incident Tracking ──────────────────────────────────────
// Records dependency failures (e.g. NZB-Service unreachable) so the admin UI
// can show a banner. Recorded reactively when an outbound service call fails;
// resolved on the next successful call. No background polling.

model ServiceIncident {
  id          String    @id @default(cuid())
  service     String                                   // "nzb-service"
  operation   String                                   // "store" | "fetch"
  status      String    @default("open")               // "open" | "resolved"
  message     String    @db.Text
  firstSeenAt DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  resolvedAt  DateTime? @map("resolved_at")
  occurrences Int       @default(1)

  @@index([service, status])
  @@map("service_incidents")
}
